#!/bin/sh

path=$1

[ -n "$path" ] || exit 0
git -C "$path" rev-parse --is-inside-work-tree >/dev/null 2>&1 || exit 0

branch=$(git -C "$path" branch --show-current 2>/dev/null)

if [ -z "$branch" ]; then
  branch=$(git -C "$path" rev-parse --short HEAD 2>/dev/null)
fi

[ -n "$branch" ] || exit 0
printf '´Éİ %s ' "$branch"
