#!/bin/sh

battery_line=$(pmset -g batt 2>/dev/null | awk 'NR == 2 { print }')
[ -n "$battery_line" ] || exit 0

percent=$(printf '%s\n' "$battery_line" | awk '{gsub(/;/, "", $3); print $3}')
[ -n "$percent" ] || exit 0

value=${percent%%%}

case $battery_line in
  *charging*|*charged*)
    icon='σΑ²³'
    ;;
  *)
    if [ "$value" -ge 90 ]; then
      icon='σΑ¹Ι'
    elif [ "$value" -ge 80 ]; then
      icon='σΑ²²'
    elif [ "$value" -ge 70 ]; then
      icon='σΑ²¹'
    elif [ "$value" -ge 60 ]; then
      icon='σΑ²Ä'
    elif [ "$value" -ge 50 ]; then
      icon='σΑ¹Ω'
    elif [ "$value" -ge 40 ]; then
      icon='σΑ¹Ψ'
    elif [ "$value" -ge 30 ]; then
      icon='σΑ¹Ϋ'
    elif [ "$value" -ge 20 ]; then
      icon='σΑ¹Φ'
    elif [ "$value" -ge 10 ]; then
      icon='σΑ¹Μ'
    else
      icon='σΑ²é'
    fi
    ;;
esac

printf '%s %s' "$icon" "$percent"
